# Ignore all files in credentials, but not the directories themselves
ansible/credentials/*
!ansible/credentials/ssh_keys/
!ansible/credentials/hosts/
ansible/credentials/ssh_keys/*
ansible/credentials/hosts/*
!ansible/credentials/ssh_keys/*.example
!ansible/credentials/ssh_keys/README.md
!ansible/credentials/hosts/README.md
!ansible/credentials/*.example

# Ignore actual configuration files but allow examples
ansible/group_vars/all.yml
ansible/group_vars/homelab.yml
ansible/inventory/hosts.yml

# Keep example files
!ansible/group_vars/*.example
!ansible/inventory/*.example

# Ignore vscode settings
.vscode/

# Ignore .ansible
.ansible/

# Ignore AI slop (idk there's probably more but these are the ones I know of)
.claude/
.cursorrules/

# Ignore public-infra repo (separate repository)
public-infra/
.github/