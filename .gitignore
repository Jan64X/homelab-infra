# Ignore all files in credentials, but not the directories themselves
credentials/*
!credentials/ssh_keys/
!credentials/hosts/
credentials/ssh_keys/*
credentials/hosts/*
!credentials/ssh_keys/*.example
!credentials/ssh_keys/README.md
!credentials/hosts/README.md
!credentials/*.example

# Ignore actual configuration files but allow examples
group_vars/all.yml
group_vars/homelab.yml
inventory/hosts.yml

# Keep example files
!group_vars/*.example
!inventory/*.example

# Ignore vscode settings
.vscode/

# Ignore .ansible
.ansible/

# Ignore AI slop (idk there's probably more but these are the ones I know of)
.claude/
.cursorrules/

# Ignore public-infra repo (separate repository)
public-infra/
.github/