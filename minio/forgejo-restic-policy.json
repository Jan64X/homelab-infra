{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowBucketDiscovery",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket",
                "s3:GetBucketLocation"
            ],
            "Resource": [
                "arn:aws:s3:::forgejo-backups"
            ]
        },
        {
            "Sid": "AllowRWOnAllObjects",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject"
            ],
            "Resource": [
                "arn:aws:s3:::forgejo-backups/*"
            ]
        },
        {
            "Sid": "AllowDeleteOnlyOnLocks",
            "Effect": "Allow",
            "Action": [
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::forgejo-backups/locks/*"
            ]
        }
    ]
}
