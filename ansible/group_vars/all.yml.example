---
# System Configuration
# Change this to your preferred username on managed systems
system_user: sysadmin
system_user_groups:
  - wheel
  - ssh

# Ansible automation user (used by Ansible to connect and manage systems)
ansible_user: ansible
ansible_user_groups: 
  - ssh

# SSH Configuration
ssh_port: 22

# Ansible User SSH Key (same for all hosts)
ansible_ssh_public_key: "{{ lookup('file', playbook_dir + '/credentials/ssh_keys/ansible_admin.pub') }}"

# ===========================================
# CLOUDFLARE / CERTBOT (playbook-wide)
# ===========================================
# Cloudflare API token for DNS-01 ACME challenges (needs Zone:DNS:Edit permission)
cloudflare_api_token: "YOUR_CLOUDFLARE_API_TOKEN_HERE"
# Email address for Let's Encrypt certificate registration
certbot_email: "admin@{{ homelab_base_domain }}"
# ===========================================

# UNBOUND DNS CONFIGURATION

