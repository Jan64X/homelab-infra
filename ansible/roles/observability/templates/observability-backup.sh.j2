#!/bin/bash
set -euo pipefail

backup_dir="/mnt/observability-backups"
timestamp="$(date '+%Y%m%d-%H%M%S')"
archive_path="${backup_dir}/observability-state-${timestamp}.tar.zst"

if ! mountpoint -q "$backup_dir"; then
    echo "ERROR: Observability backup share is not mounted at $backup_dir"
    exit 1
fi

echo "===== Observability Backup Started: $(date) ====="

# Stop services for consistent backup
echo "Stopping services..."
cd /etc/monitoring
docker compose down

echo "Writing compressed state archive..."
tar --zstd -cpf "$archive_path" -C / var/lib/prometheus var/lib/grafana var/lib/loki

# Restart services
echo "Restarting services..."
docker compose up -d

echo "===== Observability Backup Completed: $(date) ====="
