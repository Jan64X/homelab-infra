global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: 'homelab'
    replica: 'prometheus-01'
rule_files:
  # - "first_rules.yml"
  # - "second_rules.yml"
scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
    scrape_interval: 15s
    
  - job_name: 'node'
    static_configs:
      - targets: ['{{ ansible_host | default("127.0.0.1") }}:9100']
        labels:
          instance: '{{ hostname | default(inventory_hostname) }}'
          env: 'homelab'
  
  - job_name: 'fail2ban'
    static_configs:
      - targets: ['{{ ansible_host | default("127.0.0.1") }}:9191']
        labels:
          instance: '{{ hostname | default(inventory_hostname) }}'
          env: 'homelab'
  
  - job_name: 'grafana'
    static_configs:
      - targets: ['grafana:3000']
        labels:
          service: 'grafana'
          env: 'homelab'
    scrape_interval: 30s