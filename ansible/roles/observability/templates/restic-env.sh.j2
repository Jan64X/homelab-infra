#!/bin/bash
# Restic environment variables for Observability (Prometheus + Grafana)

export RESTIC_REPOSITORY="s3:{{ minio_endpoint }}/{{ minio_observability_bucket }}"
export RESTIC_PASSWORD="{{ observability_restic_password }}"
export AWS_ACCESS_KEY_ID="{{ minio_observability_access_key }}"
export AWS_SECRET_ACCESS_KEY="{{ minio_observability_secret_key }}"

# Skip TLS certificate verification for self-signed certificates
export AWS_SDK_LOAD_CONFIG=1
export RESTIC_INSECURE_TLS=true

# Optimization
# Auto compression requires Restic 0.14+
export RESTIC_COMPRESSION="auto"
