#!/bin/bash
set -euo pipefail

backup_dir="/mnt/navidrome-backups"
timestamp="$(date '+%Y%m%d-%H%M%S')"
archive_path="${backup_dir}/navidrome-data-${timestamp}.tar.zst"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

if ! mountpoint -q "$backup_dir"; then
    log "ERROR: Navidrome backup share is not mounted at $backup_dir."
    exit 1
fi

log "Starting Navidrome SMB backup..."

log "Stopping Navidrome container for consistent backup..."
cd /opt/navidrome
docker compose down

log "Writing compressed data archive..."
tar --zstd -cpf "$archive_path" -C / opt/navidrome/data

log "Starting Navidrome container..."
docker compose up -d

log "Backup archive complete."
