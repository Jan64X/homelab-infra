[Unit]
Description=Mount NAS torrents share for seedbox
After=wait-for-nas.service
Requires=wait-for-nas.service

[Mount]
What={{ seedbox_nas_share }}
Where=/mnt/torrents
Type=cifs
Options=credentials=/etc/seedbox-nas-credentials,uid=1000,gid=1000,iocharset=utf8,vers=3.0,_netdev,x-systemd.device-timeout=30s

[Install]
WantedBy=multi-user.target
