worker_processes auto;
pid /tmp/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    sendfile        on;
    tcp_nopush      on;
    tcp_nodelay     on;
    keepalive_timeout 65;

    # SSL configuration
    ssl_dhparam /etc/nginx/dhparam.pem;

    # Docker embedded DNS resolver
    resolver 127.0.0.11 valid=30s;
    resolver_timeout 5s;

    # Websocket support (needed for ntfy live connections)
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      "";
    }

    # Logging
    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                   '$status $body_bytes_sent "$http_referer" '
                   '"$http_user_agent" $request_time';

    access_log /var/log/nginx/access.log main;
    error_log  /var/log/nginx/error.log  warn;

    server_tokens off;

    # Nginx status (healthcheck)
    server {
        listen 8080;
        server_name _;
        location /nginx_status {
            stub_status on;
            access_log off;
            allow 127.0.0.0/8;
            allow 172.16.0.0/12;
            deny all;
        }
    }

    # HTTP -> HTTPS redirect
    server {
        listen 80;
        server_name {{ ntfy_domain }};
        return 301 https://$host$request_uri;
    }

    # HTTPS - ntfy reverse proxy
    server {
        listen 443 ssl;
        server_name {{ ntfy_domain }};

        ssl_certificate /etc/letsencrypt/live/{{ ntfy_domain }}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/{{ ntfy_domain }}/privkey.pem;

        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
        ssl_prefer_server_ciphers off;
        ssl_session_timeout 1d;
        ssl_session_cache shared:SSL:10m;
        ssl_session_tickets off;

        ssl_stapling on;
        ssl_stapling_verify on;

        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

        set $ntfy_upstream http://ntfy:80;

        location / {
            proxy_pass $ntfy_upstream;

            proxy_http_version 1.1;
            proxy_buffering off;

            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            # Websocket / long-poll support (ntfy uses these for subscriptions)
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;

            proxy_read_timeout 86400;
            proxy_connect_timeout 300;
        }
    }
}
