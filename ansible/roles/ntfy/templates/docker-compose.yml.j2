services:
  ntfy:
    container_name: ntfy
    image: binwiederhier/ntfy:{{ ntfy_version | default('latest') }}
    command:
      - serve
    restart: unless-stopped
    volumes:
      - /var/lib/ntfy/cache:/var/cache/ntfy
      - /var/lib/ntfy/data:/etc/ntfy
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
    environment:
      - TZ={{ ntfy_timezone }}
      - NTFY_BASE_URL={{ ntfy_base_url }}
      - NTFY_CACHE_FILE=/var/cache/ntfy/cache.db
      - NTFY_CACHE_DURATION={{ ntfy_cache_duration | default('12h') }}
      - NTFY_ATTACHMENT_CACHE_DIR=/var/cache/ntfy/attachments
      - NTFY_ATTACHMENT_TOTAL_SIZE_LIMIT={{ ntfy_attachment_total_size_limit | default('100M') }}
      - NTFY_ATTACHMENT_FILE_SIZE_LIMIT={{ ntfy_attachment_file_size_limit | default('15M') }}
      - NTFY_ATTACHMENT_EXPIRY_DURATION={{ ntfy_attachment_expiry_duration | default('3h') }}
{% if ntfy_upstream_base_url is defined and ntfy_upstream_base_url %}
      - NTFY_UPSTREAM_BASE_URL={{ ntfy_upstream_base_url }}
{% endif %}
      - NTFY_GLOBAL_TOPIC_LIMIT={{ ntfy_global_topic_limit | default('15000') }}
      - NTFY_VISITOR_REQUEST_LIMIT_BURST={{ ntfy_visitor_request_limit_burst | default('60') }}
      - NTFY_VISITOR_REQUEST_LIMIT_REPLENISH={{ ntfy_visitor_request_limit_replenish | default('5s') }}
      - NTFY_LOG_LEVEL={{ ntfy_log_level | default('INFO') }}
    cap_drop:
      - ALL
    ports:
      - "127.0.0.1:{{ ntfy_bind_port }}:80"
    healthcheck:
      test: ["CMD-SHELL", "wget -q --tries=1 http://localhost:80/v1/health -O - | grep -Eo '\"healthy\"\\s*:\\s*true' || exit 1"]
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 40s
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      homelab:
        aliases:
          - ntfy

networks:
  homelab:
    external: true
    name: {{ docker_network_name }}
