#!/bin/bash
set -euo pipefail

backup_dir="/mnt/forgejo-backups"
timestamp="$(date '+%Y%m%d-%H%M%S')"
db_archive="${backup_dir}/forgejo-db-${timestamp}.sql.zst"
data_archive="${backup_dir}/forgejo-data-${timestamp}.tar.zst"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

if ! mountpoint -q "$backup_dir"; then
    log "ERROR: Forgejo backup share is not mounted at $backup_dir."
    exit 1
fi

log "Starting Forgejo SMB backup..."

log "Writing compressed database dump..."
docker exec forgejo-db mysqldump \
    -uroot \
    -p{{ forgejo_db_root_password }} \
    --single-transaction \
    --skip-lock-tables \
    --routines \
    --triggers \
    forgejo | zstd -T0 -19 -o "$db_archive"

log "Writing compressed file archive..."
tar --zstd -cpf "$data_archive" \
    --exclude='var/lib/forgejo/data/tmp' \
    -C / \
    var/lib/forgejo/data

log "Backup archive complete."