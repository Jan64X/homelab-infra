server {
    listen 80;
    server_name {{ ingress_services[item].domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name {{ ingress_services[item].domain }};
    client_max_body_size {{ ingress_services[item].client_max_body_size | default('512M') }};

    ssl_certificate /etc/letsencrypt/live/{{ ingress_cert_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ ingress_cert_name }}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    set $service_upstream {{ ingress_services[item].backend_server }};

    location / {
        proxy_pass $service_upstream;
        proxy_http_version 1.1;
        proxy_buffering off;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        proxy_read_timeout {{ ingress_services[item].proxy_read_timeout | default(300) }};
        proxy_connect_timeout 60;
    }
}