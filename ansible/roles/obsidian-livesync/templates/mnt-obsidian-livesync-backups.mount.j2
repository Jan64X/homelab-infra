[Unit]
Description=Mount NAS backup share for Obsidian LiveSync
After=wait-for-nas.service
Requires=wait-for-nas.service

[Mount]
What={{ obsidian_livesync_backup_share }}
Where=/mnt/obsidian-livesync-backups
Type=cifs
Options=credentials=/etc/obsidian-livesync-backup-nas-credentials,uid=0,gid=0,iocharset=utf8,vers=3.0,_netdev,x-systemd.device-timeout=30s

[Install]
WantedBy=multi-user.target
