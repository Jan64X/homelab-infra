services:
  couchdb:
    image: couchdb:{{ obsidian_livesync_version }}
    container_name: obsidian-livesync
    user: "5984:5984"
    restart: unless-stopped
    environment:
      - COUCHDB_USER={{ obsidian_livesync_couchdb_user }}
      - COUCHDB_PASSWORD={{ obsidian_livesync_couchdb_password }}
    volumes:
      - /opt/obsidian-livesync/data:/opt/couchdb/data
      - /opt/obsidian-livesync/etc:/opt/couchdb/etc/local.d
    ports:
      - "127.0.0.1:{{ obsidian_livesync_port }}:5984"
    healthcheck:
      test: ["CMD-SHELL", "curl -s -o /dev/null -w '%{http_code}' http://localhost:5984/ | grep -qE '^(200|401)$'"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    networks:
      homelab:
        aliases:
          - obsidian-livesync

networks:
  homelab:
    external: true
    name: {{ docker_network_name }}
