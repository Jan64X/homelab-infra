#!/bin/bash
set -euo pipefail

backup_dir="/mnt/obsidian-livesync-backups"
timestamp="$(date '+%Y%m%d-%H%M%S')"
archive_path="${backup_dir}/obsidian-livesync-data-${timestamp}.tar.zst"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

if ! mountpoint -q "$backup_dir"; then
    log "ERROR: Obsidian LiveSync backup share is not mounted at $backup_dir."
    exit 1
fi

log "Starting Obsidian LiveSync SMB backup..."

log "Stopping CouchDB container for consistent backup..."
cd /opt/obsidian-livesync
docker compose down

log "Writing compressed data archive..."
tar --zstd -cpf "$archive_path" -C / opt/obsidian-livesync/data opt/obsidian-livesync/etc

log "Starting CouchDB container..."
docker compose up -d

log "Backup archive complete: $archive_path"
