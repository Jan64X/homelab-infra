server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: {{ promtail_loki_url }}

scrape_configs:
  # Scrape systemd journal (all systemd services)
  - job_name: journal
    journal:
      max_age: 12h
      labels:
        job: systemd-journal
        host: {{ inventory_hostname }}
    relabel_configs:
      - source_labels: ['__journal__systemd_unit']
        target_label: unit
      - source_labels: ['__journal__hostname']
        target_label: hostname
      - source_labels: ['__journal_priority_keyword']
        target_label: level

# this won't be compatible with distros that have different docker package names, but this playbook assumes Debian so meh i won't worry about it
{% if 'docker-ce' in ansible_facts.packages | default({}) %}
  # Scrape Docker container logs
  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - source_labels: ['__meta_docker_container_name']
        regex: '/(.*)'
        target_label: container_name
      - source_labels: ['__meta_docker_container_id']
        target_label: container_id
      - action: replace
        target_label: host
        replacement: {{ inventory_hostname }}
      - action: replace
        target_label: job
        replacement: docker
{% endif %}
