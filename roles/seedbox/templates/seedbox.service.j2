[Unit]
Description=Seedbox Docker Compose Application
Requires=docker.service mnt-torrents.mount
After=docker.service mnt-torrents.mount
BindsTo=mnt-torrents.mount

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/seedbox
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
