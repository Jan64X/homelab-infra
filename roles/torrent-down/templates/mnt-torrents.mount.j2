[Unit]
Description=Mount NAS torrents share for torrent-down
After=wait-for-nas.service
Requires=wait-for-nas.service

[Mount]
What={{ torrentdown_torrents_share }}
Where=/mnt/torrents
Type=cifs
Options=credentials=/etc/torrent-nas-credentials,uid=torrent,gid=torrent,iocharset=utf8,vers=3.0,_netdev,x-systemd.device-timeout=30s

[Install]
WantedBy=multi-user.target
