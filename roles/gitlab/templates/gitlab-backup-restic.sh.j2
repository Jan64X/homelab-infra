#!/bin/bash
set -euo pipefail

# Configuration
# Load Restic Environment Variables
source /opt/gitlab/restic-env.sh

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

# Check connectivity
if [ -z "${RESTIC_REPOSITORY:-}" ]; then
    log "ERROR: Restic environment variables not set."
    exit 1
fi

log "Starting GitLab Restic backup..."

# 1. Create GitLab backup
log "Creating GitLab backup archive..."
gitlab-backup create SKIP=uploads

# 2. Get the latest backup filename
BACKUP_FILE=$(ls -t /var/opt/gitlab/backups/*_gitlab_backup.tar 2>/dev/null | head -1)

if [ -z "$BACKUP_FILE" ]; then
    log "ERROR: No backup file found"
    exit 1
fi

log "Found backup: $BACKUP_FILE"

# 3. Backup the tar file to Restic
log "Uploading backup archive to Restic..."
restic backup "$BACKUP_FILE" \
    --tag gitlab-archive \
    --host {{ inventory_hostname }} \
    --insecure-tls

# 4. Backup GitLab secrets
log "Backing up GitLab secrets..."
restic backup /etc/gitlab/gitlab-secrets.json \
    --tag gitlab-secrets \
    --host {{ inventory_hostname }} \
    --insecure-tls

# 5. Backup GitLab configuration
log "Backing up GitLab configuration..."
restic backup /etc/gitlab/gitlab.rb \
    --tag gitlab-config \
    --host {{ inventory_hostname }} \
    --insecure-tls

# 6. Backup uploads separately (if they exist)
if [ -d "/var/opt/gitlab/gitlab-rails/uploads" ]; then
    log "Backing up GitLab uploads..."
    restic backup /var/opt/gitlab/gitlab-rails/uploads \
        --tag gitlab-uploads \
        --host {{ inventory_hostname }} \
        --insecure-tls
fi

# 7. Cleanup old local backups (keep last 3)
log "Cleaning up old local backups (keeping last 3)..."
cd /var/opt/gitlab/backups
ls -t *_gitlab_backup.tar 2>/dev/null | tail -n +4 | xargs rm -f || true

# 8. MAINTENANCE NOTICE
# We DO NOT prune here.
# This VM has an "Append-Only" (plus locks) policy.
# Attempting to prune will result in Access Denied errors.
# Pruning is handled by the central Admin server.

log "Backup upload complete."
