#!/bin/bash
set -euo pipefail

# Configuration
# Load Restic Environment Variables
source /opt/unifi/restic-env.sh

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

# Check connectivity
if [ -z "${RESTIC_REPOSITORY:-}" ]; then
    log "ERROR: Restic environment variables not set."
    exit 1
fi

log "Starting UniFi Controller Restic backup..."

# Backup UniFi Autobackup Directory
# The .unf backup files contain complete configuration and can be used to restore
# This is much more efficient than backing up the entire MongoDB database
log "Snapshotting UniFi Autobackup Directory..."
restic backup /var/lib/unifi/data/backup/autobackup \
    --tag unifi-backup \
    --host {{ inventory_hostname }} \
    --insecure-tls

# 3. MAINTENANCE NOTICE
# We DO NOT prune here. 
# This VM has an "Append-Only" (plus locks) policy.
# Attempting to prune will result in Access Denied errors.
# Pruning is handled by the central Admin server.

log "Backup upload complete."
